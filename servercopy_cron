#!/usr/bin/env python3.14
"""Run and monitor servercopy for cron, committing only successful runs."""

from __future__ import annotations

import argparse
from datetime import UTC, datetime
import fcntl
from http.client import HTTPException
import os
from pathlib import Path
import subprocess
import sys
from urllib.request import Request, urlopen
from uuid import UUID


SERVERCOPY_CRON_VERSION = "2.0.0"
HEALTHCHECKS_BASE_URL = "https://hc-ping.com"
HEALTHCHECKS_TIMEOUT_SECONDS = 15


class HealthchecksConfigError(ValueError):
    """A problem with the private Healthchecks.io UUID file."""


class HealthchecksPingError(RuntimeError):
    """A Healthchecks.io lifecycle ping that did not succeed."""


def utc_now() -> str:
    return datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ")


def parse_args(argv: list[str] | None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Run a monitored servercopy synchronization and commit a completed "
            "scheduled workflow."
        )
    )
    parser.add_argument(
        "-v",
        "--version",
        action="version",
        version=f"servercopy_cron {SERVERCOPY_CRON_VERSION}",
    )
    return parser.parse_args(argv)


def load_healthchecks_uuid(path: Path) -> str:
    """Load and normalize exactly one private Healthchecks.io check UUID."""

    configured_value: str | None = None
    with path.open(encoding="utf-8") as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line or line.startswith("#"):
                continue
            if configured_value is not None:
                raise HealthchecksConfigError(
                    "the Healthchecks.io UUID file contains multiple values."
                )
            configured_value = line

    if configured_value is None:
        raise HealthchecksConfigError(
            "the Healthchecks.io UUID file contains no check UUID."
        )
    if any(character.isspace() for character in configured_value):
        raise HealthchecksConfigError(
            "the Healthchecks.io check UUID contains whitespace."
        )
    try:
        return str(UUID(configured_value))
    except (AttributeError, ValueError):
        raise HealthchecksConfigError(
            "the Healthchecks.io UUID file does not contain a valid UUID."
        ) from None


def _send_healthchecks_ping(check_uuid: str, suffix: str) -> None:
    """Send one empty POST and require an HTTP-success response."""

    request = Request(
        f"{HEALTHCHECKS_BASE_URL}/{check_uuid}{suffix}",
        data=b"",
        method="POST",
    )
    try:
        with urlopen(
            request,
            timeout=HEALTHCHECKS_TIMEOUT_SECONDS,
        ) as response:
            status = response.getcode()
    except (HTTPException, OSError, ValueError):
        raise HealthchecksPingError from None

    if status is None or not 200 <= status < 300:
        raise HealthchecksPingError


def ping_start(check_uuid: str) -> None:
    """Report that a monitored run has started."""

    _send_healthchecks_ping(check_uuid, "/start")


def ping_success(check_uuid: str) -> None:
    """Report that a monitored run completed successfully."""

    _send_healthchecks_ping(check_uuid, "")


def ping_failure(check_uuid: str) -> None:
    """Report that a monitored run failed."""

    _send_healthchecks_ping(check_uuid, "/fail")


def finish_failed_run(check_uuid: str, workflow_status: int) -> int:
    """Attempt the failure ping without replacing the workflow status."""

    try:
        ping_failure(check_uuid)
    except HealthchecksPingError:
        print(
            "Error: the Healthchecks.io failure ping also failed; "
            "the original workflow failure is unchanged.",
            file=sys.stderr,
        )
    return workflow_status


def run_servercopy(command: Path, servers_repository: Path) -> int:
    """Run servercopy with live inherited output and return its status."""

    try:
        result = subprocess.run(
            [str(command), "--output", str(servers_repository)],
            check=False,
        )
    except OSError as error:
        print(f"Error: could not start servercopy: {error}", file=sys.stderr)
        return 1
    return result.returncode


def run_git(
    repository: Path, *arguments: str
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", "-C", str(repository), *arguments],
        check=False,
        capture_output=True,
        text=True,
    )


def commit_synced_changes(servers_repository: Path) -> int:
    """Stage and commit after a successful servercopy run."""

    try:
        worktree = run_git(servers_repository, "rev-parse", "--show-toplevel")
        if worktree.returncode != 0 or not worktree.stdout.strip():
            print(
                "Error: the servers directory is not a Git working tree.",
                file=sys.stderr,
            )
            return 1
        if Path(worktree.stdout.strip()).resolve() != servers_repository.resolve():
            print(
                "Error: the servers directory is not the root of its Git working tree.",
                file=sys.stderr,
            )
            return 1

        initial_index = run_git(
            servers_repository, "diff", "--cached", "--quiet", "--exit-code"
        )
        if initial_index.returncode == 1:
            print(
                "Error: refusing to stage or commit because the servers Git index "
                "already contains staged changes.",
                file=sys.stderr,
            )
            return 1
        if initial_index.returncode != 0:
            print(
                "Error: could not inspect the servers Git index "
                f"(git exit status {initial_index.returncode}).",
                file=sys.stderr,
            )
            return 1

        staged = run_git(servers_repository, "add", "-A")
        if staged.returncode != 0:
            print(
                f"Error: git add failed (exit status {staged.returncode}).",
                file=sys.stderr,
            )
            return 1

        updated_index = run_git(
            servers_repository, "diff", "--cached", "--quiet", "--exit-code"
        )
        if updated_index.returncode == 0:
            print("servercopy completed successfully; no changes to commit.")
            return 0
        if updated_index.returncode != 1:
            print(
                "Error: could not inspect the staged server changes "
                f"(git exit status {updated_index.returncode}).",
                file=sys.stderr,
            )
            return 1

        message = f"servercopy [cron]: {utc_now()}"
        committed = run_git(servers_repository, "commit", "-m", message)
        if committed.returncode != 0:
            print(
                f"Error: git commit failed (exit status {committed.returncode}).",
                file=sys.stderr,
            )
            return 1
    except OSError as error:
        print(f"Error: could not run Git: {error}", file=sys.stderr)
        return 1

    print(f"Committed synchronized server changes: {message}")
    return 0


def run_cron_workflow(
    servercopy_command: Path,
    servers_repository: Path,
    check_uuid: str,
) -> int:
    try:
        ping_start(check_uuid)
    except HealthchecksPingError:
        print(
            "Error: the Healthchecks.io start ping failed; "
            "the scheduled workflow was not started.",
            file=sys.stderr,
        )
        return 1

    servercopy_status = run_servercopy(servercopy_command, servers_repository)
    if servercopy_status != 0:
        return finish_failed_run(check_uuid, servercopy_status)

    git_status = commit_synced_changes(servers_repository)
    if git_status != 0:
        return finish_failed_run(check_uuid, git_status)

    try:
        ping_success(check_uuid)
    except HealthchecksPingError:
        print(
            "Error: the Healthchecks.io success ping failed after the scheduled "
            "workflow completed.",
            file=sys.stderr,
        )
        return 1
    return 0


def main(argv: list[str] | None = None) -> int:
    parse_args(argv)
    mermaid = os.environ.get("MERMAID")
    if not mermaid:
        print("Error: MERMAID must be set before running this script.", file=sys.stderr)
        return 1

    mermaid_root = Path(mermaid)
    repository_root = Path(__file__).resolve().parent
    servers_repository = mermaid_root / "servers"
    healthchecks_uuid_path = repository_root / "data" / "healthchecks_uuid.txt"
    servercopy_command = repository_root / "servercopy"
    lock_path = mermaid_root / "logs" / "servercopy_cron.lock"

    try:
        lock_path.parent.mkdir(parents=True, exist_ok=True)
        lock = lock_path.open("a", encoding="ascii")
    except OSError as error:
        print(
            f"Error: could not prepare the servercopy_cron lock: {error}",
            file=sys.stderr,
        )
        return 1

    with lock:
        try:
            fcntl.flock(lock.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            print(
                "Error: another servercopy_cron invocation is already running.",
                file=sys.stderr,
            )
            return 1
        except OSError as error:
            print(
                f"Error: could not acquire the servercopy_cron lock: {error}",
                file=sys.stderr,
            )
            return 1

        try:
            check_uuid = load_healthchecks_uuid(healthchecks_uuid_path)
        except HealthchecksConfigError as error:
            print(f"Error: {error}", file=sys.stderr)
            return 1
        except (OSError, UnicodeError):
            print(
                "Error: the Healthchecks.io UUID file could not be read.",
                file=sys.stderr,
            )
            return 1

        return run_cron_workflow(
            servercopy_command,
            servers_repository,
            check_uuid,
        )


if __name__ == "__main__":
    raise SystemExit(main())
