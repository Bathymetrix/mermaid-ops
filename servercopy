#!/usr/bin/env python3.14
"""Mirror configured MERMAID server sources with lftp."""

from __future__ import annotations

import argparse
import csv
from datetime import UTC, datetime
import fcntl
import os
from pathlib import Path
from queue import Empty, Queue
import re
import shutil
import subprocess
import sys
from threading import Thread
import time
import traceback
from typing import NamedTuple, TextIO


SERVERCOPY_VERSION = "1.4.1"
SOURCE_FIELDS = ("user", "login", "protocol", "host", "port", "remote_root")
LEDGER_HEADER = "user,result,start,end,ver"
COMMON_OPTIONS = (
    "--verbose",
    "--continue",
    "--overwrite",
    "--no-perms",
    "--parallel=4",
)
SUFFIX_ALLOWLIST = Path(__file__).resolve().parent / "data" / "filename_suffixes.txt"
SUFFIX_ENTRY = re.compile(r"(?:[A-Za-z0-9]+|(?:\[0-9\])+)$")
CREDENTIAL_URL = re.compile(r"((?:sftp|ftp(?:\+tls)?)://)[^/\s]+@")
HEARTBEAT_SECONDS = 30.0
LFTP_SILENCE_TIMEOUT_SECONDS = 300.0
LISTING_BEGIN_MARKER = "[servercopy] listing-begin"
LISTING_END_MARKER = "[servercopy] listing-end"
LFTP_DIAGNOSTIC_PREFIXES = (
    "mirror:", "open:", "cls:", "cd:", "get:", "put:", "mget:", "pget:"
)


class ConfigError(Exception):
    pass


class Source(NamedTuple):
    user: str
    login: str
    protocol: str
    host: str
    port: int
    remote_root: str


class Reporter:
    """Write to the terminal and, when enabled, one transcript file."""

    def __init__(self, log_path: Path | None = None) -> None:
        self.log = log_path.open("a", encoding="utf-8", newline="") if log_path else None

    def close(self) -> None:
        if self.log:
            self.log.close()

    def write(self, text: str = "", *, error: bool = False) -> None:
        message = f"{text}\n"
        stream: TextIO = sys.stderr if error else sys.stdout
        stream.write(message)
        stream.flush()
        if self.log:
            self.log.write(message)
            self.log.flush()


def utc_now() -> str:
    return datetime.now(UTC).strftime("%Y-%m-%dT%H:%M:%SZ")


def quote(value: str) -> str:
    return f'"{value.replace("\\", "\\\\").replace(chr(34), "\\\"")}"'


def mirror(arguments: list[str]) -> str:
    return "mirror " + " ".join(quote(argument) for argument in arguments)


def build_lftp_script(
    source: Source,
    password: str,
    destination: Path,
    preview: bool,
    suffix_globs: tuple[str, ...],
) -> str:
    """Build lftp input for one source; the password never enters process argv."""

    if not suffix_globs:
        raise ConfigError("filename suffix allowlist is empty")
    lines = [
        "set cmd:fail-exit yes",
        "set net:timeout 30s",
        "set net:max-retries 2",
        "set xfer:timeout 5m",
    ]
    if source.protocol == "sftp":
        lines.append("set sftp:auto-confirm yes")
        url = f"sftp://{source.host}:{source.port}"
    elif source.protocol == "ftps-explicit":
        lines.extend(
            [
                "set ftp:ssl-force yes",
                "set ftp:ssl-protect-data yes",
                "set ftp:ssl-protect-list yes",
                "set ssl:verify-certificate yes",
            ]
        )
        url = f"ftp://{source.host}:{source.port}"
    else:
        raise ConfigError(f"unsupported protocol for {source.user}: {source.protocol}")

    lines.append(f"open -u {quote(source.login)},{quote(password)} {quote(url)}")
    dry_run = ["--dry-run"] if preview else []
    root = source.remote_root.rstrip("/") or "."
    lines.append(
        f"echo {quote(f'[servercopy] step=selected-files patterns={len(suffix_globs)}')}"
    )
    # The clever repeated --file mirror stalled during a live Taal run. Stick
    # to one nonrecursive mirror and lftp's documented repeatable include globs
    # for the operator-maintained suffix allowlist.
    lines.append(
        mirror(
            [
                *COMMON_OPTIONS,
                "--no-recursion",
                *dry_run,
                "--exclude-glob=*",
                *(f"--include-glob=*{suffix}" for suffix in suffix_globs),
                root,
                str(destination),
            ]
        )
    )
    return "\n".join([*lines, "bye", ""])


def build_listing_lftp_script(source: Source, password: str, listing_tls: str) -> str:
    """Build a read-only explicit-FTPS directory-listing diagnostic."""

    if source.protocol != "ftps-explicit":
        raise ConfigError("listing diagnostics are supported only for explicit FTPS")
    try:
        protect_list = {"protected": "yes", "unprotected": "no"}[listing_tls]
    except KeyError as error:
        raise ConfigError(f"invalid listing TLS mode: {listing_tls}") from error
    root = source.remote_root.rstrip("/")
    listing_target = "." if root in {"", "."} else f"{root}/"
    return "\n".join([
        "set cmd:trace no",
        "set cmd:fail-exit yes",
        'set cmd:cls-default ""',
        "set cmd:save-cwd-history no",
        "set cmd:save-rl-history no",
        "set net:timeout 30s",
        "set net:max-retries 2",
        "set xfer:timeout 5m",
        "set ftp:ssl-force yes",
        "set ftp:ssl-protect-data yes",
        f"set ftp:ssl-protect-list {protect_list}",
        "set ftp:use-stat-for-list no",
        "set ftp:list-empty-ok yes",
        "set ssl:verify-certificate yes",
        f'open -u {quote(source.login)},{quote(password)} '
        f'{quote(f"ftp://{source.host}:{source.port}")}',
        f"command cd {quote(listing_target)}",
        f"echo {quote(LISTING_BEGIN_MARKER)}",
        'command cls -1 -q -B "."',
        f"echo {quote(LISTING_END_MARKER)}",
        "bye",
        "",
    ])


def parse_args(argv: list[str] | None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Mirror configured MERMAID server sources.")
    modes = parser.add_mutually_exclusive_group()
    modes.add_argument("-c", "--check", action="store_true", help="validate locally only")
    modes.add_argument("--dry-run", action="store_true", help="preview remote mirrors")
    modes.add_argument(
        "--diagnose-listing",
        action="store_true",
        help="authenticate and list one explicit-FTPS source without writing files",
    )
    parser.add_argument(
        "--listing-tls",
        choices=("protected", "unprotected"),
        help="directory-listing data-channel TLS for --diagnose-listing",
    )
    parser.add_argument("-u", "--user", metavar="USERS", help="comma-separated logical users")
    parser.add_argument(
        "-o",
        "--output",
        type=Path,
        default=Path.home() / "mermaid" / "servers",
        metavar="DIR",
        help="server output root (default: ~/mermaid/servers/)",
    )
    parser.add_argument(
        "-v", "--version", action="version", version=f"servercopy {SERVERCOPY_VERSION}"
    )
    args = parser.parse_args(argv)
    if args.listing_tls is not None and not args.diagnose_listing:
        parser.error("--listing-tls requires --diagnose-listing")
    return args


def valid_name(value: str) -> bool:
    return (
        bool(value)
        and value not in {".", ".."}
        and not any(character in value for character in '/,"\\')
        and not any(character.isspace() for character in value)
    )


def load_sources(path: Path) -> list[Source]:
    try:
        handle = path.open(encoding="ascii", newline="")
    except OSError as error:
        raise ConfigError(f"cannot read source registry: {path}: {error}") from error

    sources: list[Source] = []
    seen: set[str] = set()
    with handle:
        reader = csv.reader(handle)
        if tuple(next(reader, ())) != SOURCE_FIELDS:
            raise ConfigError(f"unexpected source registry header in {path}")
        for line_number, row in enumerate(reader, 2):
            if not row:
                continue
            if len(row) != len(SOURCE_FIELDS):
                raise ConfigError(f"malformed source registry line {line_number} in {path}")
            user, login, protocol, host, port_text, remote_root = (
                value.strip() for value in row
            )
            if not valid_name(user) or not valid_name(login):
                raise ConfigError(f"unsafe user or login on source line {line_number}")
            if user in seen:
                raise ConfigError(f"duplicate logical user on source line {line_number}: {user}")
            if protocol not in {"sftp", "ftps-explicit"}:
                raise ConfigError(f"unsupported protocol on source line {line_number}: {protocol}")
            try:
                port = int(port_text)
            except ValueError as error:
                raise ConfigError(
                    f"invalid port on source line {line_number}: {port_text}"
                ) from error
            if not host or not remote_root or not 1 <= port <= 65535:
                raise ConfigError(f"invalid endpoint on source line {line_number}")
            sources.append(Source(user, login, protocol, host, port, remote_root))
            seen.add(user)
    if not sources:
        raise ConfigError(f"no sources configured in {path}")
    return sources


def load_suffix_globs(path: Path) -> tuple[str, ...]:
    try:
        lines = path.read_text(encoding="ascii").splitlines()
    except (OSError, UnicodeError) as error:
        raise ConfigError(f"cannot read filename suffix allowlist: {path}: {error}") from error

    suffixes: list[str] = []
    seen: set[str] = set()
    for line_number, line in enumerate(lines, 1):
        value = line.strip()
        if not value or value.startswith("#"):
            continue
        if not SUFFIX_ENTRY.fullmatch(value):
            raise ConfigError(f"malformed filename suffix line {line_number} in {path}")
        if value in seen:
            raise ConfigError(f"duplicate filename suffix on line {line_number}: {value}")
        suffixes.append(f".{value}")
        seen.add(value)
    if not suffixes:
        raise ConfigError(f"no filename suffixes configured in {path}")
    return tuple(suffixes)


def load_credentials(path: Path) -> dict[str, str]:
    """Read the simple, headerless login,password registry."""

    try:
        handle = path.open(encoding="utf-8", newline="")
    except OSError as error:
        raise ConfigError(f"cannot read credentials file: {path}: {error}") from error

    credentials: dict[str, str] = {}
    with handle:
        for line_number, raw in enumerate(handle, 1):
            line = raw.rstrip("\r\n")
            if not line.strip() or line.lstrip().startswith("#"):
                continue
            fields = line.split(",")
            if (
                len(fields) != 2
                or not valid_name(fields[0])
                or not fields[1]
                or '"' in line
                or "\\" in line
                or any(character.isspace() for character in fields[1])
            ):
                raise ConfigError(f"malformed credentials line {line_number} in {path}")
            login, password = fields
            if login in credentials:
                raise ConfigError(f"duplicate credential login on line {line_number}: {login}")
            credentials[login] = password
    if not credentials:
        raise ConfigError(f"no credentials configured in {path}")
    return credentials


def requested_users(value: str | None) -> list[str] | None:
    if value is None:
        return None
    users = [item.strip() for item in value.split(",")]
    if not users or any(not user for user in users):
        raise ConfigError("--user contains an empty username")
    return list(dict.fromkeys(users))


def prepare_ledger(path: Path) -> None:
    if not path.exists():
        path.write_text(f"{LEDGER_HEADER}\n", encoding="ascii")
        return
    with path.open(encoding="ascii", newline="") as handle:
        if handle.readline().rstrip("\r\n") != LEDGER_HEADER:
            raise ConfigError(f"unexpected run ledger header in {path}")


def append_ledger(path: Path, user: str, result: str, start: str, end: str = "") -> None:
    with path.open("a", encoding="ascii", newline="") as handle:
        handle.write(f"{user},{result},{start},{end},{SERVERCOPY_VERSION}\n")


def remote_url(source: Source) -> str:
    scheme = "sftp" if source.protocol == "sftp" else "ftp+tls"
    return f"{scheme}://{source.host}:{source.port}"


def run_lftp(
    executable: str,
    script: str,
    report: Reporter,
    label: str,
    user: str,
    heartbeat_seconds: float = HEARTBEAT_SECONDS,
    silence_timeout_seconds: float = LFTP_SILENCE_TIMEOUT_SECONDS,
    norc: bool = False,
) -> tuple[int, list[str]]:
    """Run lftp while streaming redacted lines and reporting silent intervals."""

    try:
        process = subprocess.Popen(
            [executable, *(["--norc"] if norc else [])],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
        )
    except OSError as error:
        detail = f"could not start lftp: {error}"
        report.write(detail, error=True)
        return 1, [detail]

    assert process.stdin is not None
    assert process.stdout is not None
    pending: Queue[bytes | None] = Queue()

    def read_output() -> None:
        try:
            for raw_line in iter(process.stdout.readline, b""):
                pending.put(raw_line)
        finally:
            pending.put(None)

    reader = Thread(target=read_output, name="servercopy-lftp-output", daemon=True)
    reader.start()
    input_detail: str | None = None
    try:
        process.stdin.write(script.encode("utf-8"))
    except OSError as error:
        input_detail = f"could not send lftp commands: {error}"
        report.write(input_detail, error=True)
    finally:
        try:
            process.stdin.close()
        except OSError as error:
            if input_detail is None:
                input_detail = f"could not close lftp input: {error}"
                report.write(input_detail, error=True)

    lines: list[str] = []
    started = time.monotonic()
    last_output = started

    def stop_process() -> None:
        process.terminate()
        try:
            process.wait(timeout=5)
        except subprocess.TimeoutExpired:
            process.kill()
            process.wait()

    timed_out = False
    try:
        while True:
            try:
                raw_line = pending.get(timeout=heartbeat_seconds)
            except Empty:
                now = time.monotonic()
                silent = now - last_output
                if silent >= silence_timeout_seconds:
                    detail = (
                        f"lftp timed out after {int(silent)}s without output; terminating"
                    )
                    report.write(detail, error=True)
                    lines.append(detail)
                    timed_out = True
                    stop_process()
                    break
                report.write(
                    f"[{label}] still-running user={user} "
                    f"elapsed={int(now - started)}s silent={int(silent)}s"
                )
                continue
            if raw_line is None:
                break
            line = redact_lftp_output(
                raw_line.decode("utf-8", errors="replace").rstrip("\r\n")
            )
            report.write(line)
            lines.append(line)
            last_output = time.monotonic()
    except KeyboardInterrupt:
        stop_process()
        raise
    finally:
        reader.join(timeout=1)
        process.stdout.close()

    if input_detail:
        lines.append(input_detail)
    return (124 if timed_out else process.wait()), lines


def redact_lftp_output(text: str) -> str:
    return CREDENTIAL_URL.sub(r"\1[REDACTED]@", text)


def lftp_failure_detail(code: int, lines: list[str]) -> str:
    diagnostics = [
        line
        for line in lines
        if line.lower().startswith(LFTP_DIAGNOSTIC_PREFIXES)
        or any(
            word in line.lower()
            for word in ("error", "failed", "denied", "illegal", "refused", "timed out")
        )
    ]
    detail = [f"lftp exit status {code}"]
    if diagnostics:
        detail.extend(diagnostics[-10:])
    else:
        detail.append("no diagnostic line; see inline lftp output")
    return "\n".join(detail)


def listing_entry_count(lines: list[str]) -> int | None:
    try:
        begin = lines.index(LISTING_BEGIN_MARKER)
        end = lines.index(LISTING_END_MARKER, begin + 1)
    except ValueError:
        return None
    return sum(1 for line in lines[begin + 1 : end] if line)


def run_workflow(args: argparse.Namespace, root: Path, report: Reporter) -> int:
    sources_path = Path(__file__).resolve().with_name("servercopy_sources.csv")
    credentials_path = root / "passwords" / "servercopy_credentials.csv"
    server_root = args.output.expanduser()
    ledger = server_root / "_runs" / "servercopy_runs.csv"
    lftp = shutil.which("lftp")
    if not lftp:
        report.write("Error: lftp is required but was not found on PATH.", error=True)
        return 1

    try:
        sources = load_sources(sources_path)
        suffix_globs = () if args.diagnose_listing else load_suffix_globs(SUFFIX_ALLOWLIST)
        override = os.environ.get("SFTP_PORT")
        if override:
            if not override.isdecimal() or not 1 <= int(override) <= 65535:
                raise ConfigError("SFTP_PORT must be numeric and between 1 and 65535")
            sources = [
                source._replace(port=int(override)) if source.protocol == "sftp" else source
                for source in sources
            ]
        requested = requested_users(args.user)
        if args.diagnose_listing and (requested is None or len(requested) != 1):
            raise ConfigError("--diagnose-listing requires exactly one logical user via --user")
        configured = {source.user for source in sources}
        missing_users = [user for user in requested or [] if user not in configured]
        if requested is not None:
            sources = [source for source in sources if source.user in set(requested)]
        if not sources:
            raise ConfigError(f"no requested users were found in {sources_path}")
        if args.diagnose_listing and sources[0].protocol != "ftps-explicit":
            raise ConfigError("--diagnose-listing is supported only for explicit-FTPS sources")
        credentials = load_credentials(credentials_path)
        missing_logins = sorted({source.login for source in sources} - credentials.keys())
        if missing_logins:
            raise ConfigError("missing credential login(s): " + ",".join(missing_logins))
        if not args.check and not args.dry_run and not args.diagnose_listing:
            prepare_ledger(ledger)
    except (ConfigError, OSError) as error:
        report.write(f"Error: {error}", error=True)
        return 1

    failures: dict[str, list[str]] = {}
    warnings: list[str] = []

    def fail(user: str, detail: str) -> None:
        lines: list[str] = []
        for line in detail.splitlines():
            if line.lower().startswith("warning:"):
                warnings.append(line)
            elif line:
                lines.append(line)
        failures[user] = lines

    for source in sources:
        remote = remote_url(source)

        if args.check:
            destination = server_root / source.user
            for key, value in (
                ("user", source.user),
                ("login", source.login),
                ("remote", remote),
                ("remote-root", source.remote_root),
                ("destination", str(destination)),
            ):
                report.write(f"[check] {key}={value}")
            report.write()
            if destination.exists() and not destination.is_dir():
                fail(source.user, f"destination exists but is not a directory: {destination}")
            continue

        if args.diagnose_listing:
            label = "diagnose-listing"
            listing_tls = args.listing_tls or "protected"
            report.write(f"[{label}] user={source.user}")
            report.write(f"[{label}] remote-root={source.remote_root}")
            report.write(f"[{label}] listing-tls={listing_tls}")
            report.write(f"[{label}] lftp directory listing output follows:")

            lftp_started = time.monotonic()
            code, lines = run_lftp(
                lftp,
                build_listing_lftp_script(
                    source,
                    credentials[source.login],
                    listing_tls,
                ),
                report,
                label,
                source.user,
                norc=True,
            )
            elapsed = int(time.monotonic() - lftp_started)
            count = listing_entry_count(lines)
            if code == 0 and count is not None:
                report.write(
                    f"[{label}] listing succeeded user={source.user} "
                    f"entries={count} elapsed={elapsed}s"
                )
            else:
                status = (
                    "timed out"
                    if code == 124 and any("timed out" in line for line in lines)
                    else "failed"
                )
                report.write(f"[{label}] listing {status} user={source.user} elapsed={elapsed}s")
                detail = lftp_failure_detail(code, lines)
                if count is None:
                    detail += "\nlisting completion marker was not received"
                fail(source.user, detail)
            report.write()
            continue

        destination = server_root / source.user
        start = utc_now()
        if not args.dry_run:
            try:
                destination.mkdir(parents=True, exist_ok=True)
                if not destination.is_dir():
                    raise OSError("destination is not a directory")
            except OSError as error:
                fail(source.user, f"could not create destination directory: {destination}: {error}")
                append_ledger(ledger, source.user, "failure", start)
                continue

        label = "dry-run" if args.dry_run else "sync"
        report.write(f"[{label}] user={source.user}")
        report.write(f"[{label}] login={source.login}")
        report.write(f"[{label}] remote={remote}")
        report.write(f"[{label}] remote-root={source.remote_root}")
        report.write(f"[{label}] destination={destination}")
        report.write(f"[{label}] lftp mirror {'preview' if args.dry_run else 'output'} follows:")

        lftp_started = time.monotonic()
        code, lines = run_lftp(
            lftp,
            build_lftp_script(
                source,
                credentials[source.login],
                destination,
                args.dry_run,
                suffix_globs,
            ),
            report,
            label,
            source.user,
        )
        warnings.extend(
            f"Warning: {source.user}: {line.removeprefix('Warning:').lstrip()}"
            for line in lines
            if line.lower().startswith("warning:")
        )
        result = "success" if code == 0 else "failure"
        report.write(
            f"[{label}] result={result} user={source.user} "
            f"lftp-exit={code} elapsed={int(time.monotonic() - lftp_started)}s"
        )
        if code == 0:
            if not args.dry_run:
                append_ledger(ledger, source.user, "success", start, utc_now())
        else:
            fail(source.user, lftp_failure_detail(code, lines))
            if not args.dry_run:
                append_ledger(ledger, source.user, "failure", start)
        report.write()

    report.write("##########################################################")
    warnings.extend(
        f"Warning: requested user not found in source registry: {user}"
        for user in missing_users
    )
    for warning in warnings:
        report.write(warning, error=True)
    if failures:
        report.write("\nFailures:", error=True)
        for user, lines in failures.items():
            report.write(f"  {user}", error=True)
            for line in lines:
                report.write(f"    {line}", error=True)
        return 1

    if args.check:
        report.write(f"DONE: local check completed for {server_root}")
    elif args.diagnose_listing:
        report.write("DONE: directory listing diagnostic completed")
    elif args.dry_run:
        report.write(f"DONE: dry run completed for {server_root}")
    else:
        report.write(f"DONE: synced all accounts to {server_root}")
    report.write("##########################################################")
    return 0


def guarded_workflow(args: argparse.Namespace, root: Path, report: Reporter) -> int:
    try:
        return run_workflow(args, root, report)
    except KeyboardInterrupt:
        report.write("Error: interrupted.", error=True)
        return 130
    except Exception:
        report.write("Error: unexpected servercopy failure:", error=True)
        report.write(traceback.format_exc().rstrip(), error=True)
        return 1


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)
    if not (mermaid := os.environ.get("MERMAID")):
        print("Error: MERMAID must be set before running this script.", file=sys.stderr)
        return 1
    root = Path(mermaid)

    if args.check or args.diagnose_listing:
        report = Reporter()
        try:
            return guarded_workflow(args, root, report)
        finally:
            report.close()

    runs = args.output.expanduser() / "_runs"
    try:
        runs.mkdir(parents=True, exist_ok=True)
        lock = (runs / "servercopy.lock").open("a+", encoding="ascii")
    except OSError as error:
        print(f"Error: cannot prepare run logging: {error}", file=sys.stderr)
        return 1

    with lock:
        try:
            fcntl.flock(lock.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            print("Error: another servercopy invocation is already running.", file=sys.stderr)
            return 1
        log_path = runs / f"servercopy_{utc_now()}.log"
        try:
            report = Reporter(log_path)
        except OSError as error:
            print(f"Error: cannot create transcript log: {error}", file=sys.stderr)
            return 1
        try:
            return guarded_workflow(args, root, report)
        finally:
            report.close()


if __name__ == "__main__":
    raise SystemExit(main())
